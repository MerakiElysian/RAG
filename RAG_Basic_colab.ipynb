        "\n",
        "pairs = [(query, chunk.page_content)  for chunk in retrieved_chunks]\n",
        "scores = reranker.predict(pairs)\n",
        "\n",
        "ranked_chunks = sorted(zip(scores, retrieved_chunks), key = lambda x:x[0], reverse = True )\n",
